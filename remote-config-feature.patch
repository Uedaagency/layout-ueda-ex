diff --git a/src/routes/api/public/remote-config.ts b/src/routes/api/public/remote-config.ts
new file mode 100644
index 0000000..3317d74
--- /dev/null
+++ b/src/routes/api/public/remote-config.ts
@@ -0,0 +1,95 @@
+import { createFileRoute } from "@tanstack/react-router";
+
+// ============================================================
+// GET /api/public/remote-config
+// ------------------------------------------------------------
+// Serve a configuração dinâmica da extensão lendo a tabela
+// `remote_config` no Supabase SERVER-SIDE. A extensão nunca
+// precisa saber a estrutura da tabela nem a URL do Supabase.
+//
+// Segurança / MV3:
+//   - Apenas leitura. Retorna DADOS e CONFIG (flags, params,
+//     texts, links). Nunca código executável.
+//   - Usa a anon key (somente SELECT liberado por RLS). Mesmo
+//     que vaze, não dá escrita.
+//   - CORS "*" liberado: origem chrome-extension:// não manda
+//     Origin previsível, e é só leitura de config pública.
+// ============================================================
+
+const SUPABASE_URL =
+  process.env.SUPABASE_URL ?? "https://qpssaefptonzbpgcvtrq.supabase.co";
+const SUPABASE_ANON = process.env.SUPABASE_ANON_KEY ?? "";
+
+const REST_URL =
+  SUPABASE_URL +
+  "/rest/v1/remote_config" +
+  "?id=eq.1&select=config_version,flags,params,texts,links,updated_at&limit=1";
+
+const CORS: Record<string, string> = {
+  "Access-Control-Allow-Origin": "*",
+  "Access-Control-Allow-Methods": "GET, OPTIONS",
+  "Access-Control-Allow-Headers": "content-type",
+};
+
+// Fallback servido se o Supabase estiver fora do ar. A extensão
+// usa o cache local, mas isto evita que ela veja um erro HTTP.
+const FALLBACK = {
+  config_version: 0,
+  flags: {},
+  params: { poll_interval_ms: 20000 },
+  texts: {},
+  links: {},
+  updated_at: null as string | null,
+  _stale: true as const,
+};
+
+async function readConfig() {
+  if (!SUPABASE_ANON) return FALLBACK;
+
+  const controller = new AbortController();
+  const timer = setTimeout(() => controller.abort(), 6000);
+  try {
+    const resp = await fetch(REST_URL, {
+      headers: {
+        apikey: SUPABASE_ANON,
+        Authorization: "Bearer " + SUPABASE_ANON,
+      },
+      signal: controller.signal,
+    });
+    if (!resp.ok) return FALLBACK;
+    const rows = (await resp.json()) as Array<Record<string, unknown>>;
+    const row = Array.isArray(rows) ? rows[0] : null;
+    if (!row) return FALLBACK;
+    return {
+      config_version: Number(row.config_version) || 0,
+      flags: row.flags ?? {},
+      params: row.params ?? {},
+      texts: row.texts ?? {},
+      links: row.links ?? {},
+      updated_at: (row.updated_at as string) ?? null,
+    };
+  } catch {
+    return FALLBACK;
+  } finally {
+    clearTimeout(timer);
+  }
+}
+
+export const Route = createFileRoute("/api/public/remote-config")({
+  server: {
+    handlers: {
+      OPTIONS: () => new Response(null, { headers: CORS }),
+      GET: async () => {
+        const config = await readConfig();
+        return new Response(JSON.stringify(config), {
+          status: 200,
+          headers: {
+            ...CORS,
+            "Content-Type": "application/json",
+            "Cache-Control": "public, max-age=15, s-maxage=15",
+          },
+        });
+      },
+    },
+  },
+});
diff --git a/supabase-remote-config.sql b/supabase-remote-config.sql
new file mode 100644
index 0000000..eb7853e
--- /dev/null
+++ b/supabase-remote-config.sql
@@ -0,0 +1,85 @@
+-- ============================================================
+-- remote_config — configuração dinâmica servida à extensão
+-- ------------------------------------------------------------
+-- Uma única linha (id = 1) versionada. A extensão compara
+-- `config_version`; quando muda, mostra o toast "Atualizar".
+--
+-- IMPORTANTE (MV3): esta tabela guarda apenas DADOS e CONFIG
+-- (textos, flags, parâmetros, links). NUNCA guarde código-fonte
+-- ou trechos de JS para serem executados — isso viola o Manifest
+-- V3 e é motivo de remoção da Chrome Web Store.
+-- ============================================================
+
+create table if not exists public.remote_config (
+  id             integer primary key default 1,
+  config_version integer not null default 1,
+  flags          jsonb   not null default '{}'::jsonb,
+  params         jsonb   not null default '{}'::jsonb,
+  texts          jsonb   not null default '{}'::jsonb,
+  links          jsonb   not null default '{}'::jsonb,
+  updated_at     timestamptz not null default now(),
+  constraint remote_config_singleton check (id = 1)
+);
+
+-- Bump automático de config_version + updated_at a cada UPDATE,
+-- para a extensão nunca depender de o admin lembrar de incrementar.
+create or replace function public.bump_remote_config_version()
+returns trigger
+language plpgsql
+as $$
+begin
+  new.updated_at := now();
+  if new.config_version <= old.config_version then
+    new.config_version := old.config_version + 1;
+  end if;
+  return new;
+end;
+$$;
+
+drop trigger if exists trg_bump_remote_config on public.remote_config;
+create trigger trg_bump_remote_config
+  before update on public.remote_config
+  for each row
+  execute function public.bump_remote_config_version();
+
+-- Linha inicial (idempotente)
+insert into public.remote_config (id, config_version, flags, params, texts, links)
+values (
+  1,
+  1,
+  '{
+    "migrar_cloud_enabled": false,
+    "beta_panel": false
+  }'::jsonb,
+  '{
+    "poll_interval_ms": 20000,
+    "max_projects": 10
+  }'::jsonb,
+  '{
+    "pt-BR": {
+      "btn_migrate": "Migrar Cloud",
+      "update_available": "Nova configuração disponível",
+      "update_action": "Atualizar"
+    }
+  }'::jsonb,
+  '{
+    "support": "https://wa.me/5561998239879",
+    "sales": "https://wa.me/5561998239879"
+  }'::jsonb
+)
+on conflict (id) do nothing;
+
+-- ---------- RLS ----------
+-- Leitura pública (anon) apenas SELECT. Escrita só via service_role
+-- (painel admin server-side). A extensão só lê.
+alter table public.remote_config enable row level security;
+
+drop policy if exists "remote_config public read" on public.remote_config;
+create policy "remote_config public read"
+  on public.remote_config
+  for select
+  to anon, authenticated
+  using (true);
+
+-- (Nenhuma policy de INSERT/UPDATE/DELETE para anon: bloqueado por padrão.
+--  O painel admin escreve usando a service_role key, que bypassa RLS.)
-- 
2.43.0

